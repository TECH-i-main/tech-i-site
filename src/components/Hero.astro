---

---

<section
  id="home"
  class="relative min-h-screen pt-20 flex items-center justify-center overflow-hidden"
>
  <div
    class="absolute inset-0 bg-gradient-to-br from-coral-600 via-coral-500 to-coral-700 opacity-20"
  >
  </div>
  <div
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-coral-900/20 to-transparent"
  >
  </div>

  <!-- Performance Optimization: Hide heavy CSS blobs on mobile -->
  <div
    class="hidden md:block absolute top-20 left-10 w-72 h-72 bg-coral-500 rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-blob"
  >
  </div>
  <div
    class="hidden md:block absolute top-40 right-10 w-72 h-72 bg-coral-400 rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-blob animation-delay-2000"
  >
  </div>
  <div
    class="hidden md:block absolute -bottom-8 left-1/2 w-72 h-72 bg-coral-600 rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-blob animation-delay-4000"
  >
  </div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="mb-8 animate-fade-in" style="animation-duration: 0.5s;">
      <img
        src="/assets/images/logo_v.svg"
        alt="TECH-i"
        class="h-24 w-auto mx-auto drop-shadow-2xl"
        fetchpriority="high"
        width="96"
        height="96"
      />
    </div>

    <h1
      class="text-5xl sm:text-6xl lg:text-7xl font-black font-plus-jakarta leading-tight mb-6 text-white drop-shadow-2xl animate-fade-in"
      style="animation-duration: 0.5s; animation-delay: 0.1s;"
    >
      テクノロジーを、<br /><span
        class="bg-gradient-to-r from-coral-400 to-coral-600 bg-clip-text text-transparent"
        >貴社の「右腕」に。</span
      >
    </h1>

    <p
      class="text-lg sm:text-xl text-gray-200 max-w-2xl mx-auto mb-12 leading-relaxed animate-fade-in"
      style="animation-duration: 0.5s; animation-delay: 0.2s;"
    >
      単なる開発業者ではなく、ビジネスを前進させる技術パートナーとして。<br />
      大規模システム開発で培った圧倒的な技術力を、スピーディかつ柔軟に提供します。
    </p>

    <div
      class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in"
      style="animation-duration: 0.5s; animation-delay: 0.3s;"
    >
      <a
        href="#contact"
        class="group relative px-8 py-4 bg-coral-600 text-white hover:text-white font-semibold rounded-lg hover:bg-coral-700 transition-all duration-300 shadow-lg hover:shadow-coral-500/50 overflow-hidden"
      >
        <span class="relative z-10">問い合わせ</span>
        <div
          class="absolute inset-0 bg-gradient-to-r from-coral-500 to-coral-700 opacity-0 group-hover:opacity-100 transition-opacity"
        >
        </div>
      </a>
      <a
        href="#services"
        class="px-8 py-4 border-2 border-coral-500 text-white hover:text-white font-semibold rounded-lg hover:bg-coral-500/10 transition-all duration-300"
      >
        サービス一覧
      </a>
    </div>
  </div>

  <div
    class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce"
  >
    <svg
      class="w-6 h-6 text-coral-400"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>
