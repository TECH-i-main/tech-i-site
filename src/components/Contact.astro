---
// Contact.astro
import ContactForm from "./ContactForm";
import FadeIn from "./FadeIn";
---

<section
  id="contact"
  class="relative py-24 px-4 sm:px-6 lg:px-8 overflow-hidden"
>
  <!-- Background Elements -->
  <div
    class="absolute inset-0 bg-gradient-to-br from-red-900/20 to-transparent"
  >
  </div>
  <div
    class="absolute top-0 right-0 w-[500px] h-[500px] bg-red-600/10 rounded-full blur-[100px] opacity-50"
  >
  </div>
  <div
    class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-blue-600/10 rounded-full blur-[100px] opacity-30"
  >
  </div>

  <div class="relative z-10 max-w-5xl mx-auto">
    <FadeIn client:visible className="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-black font-plus-jakarta mb-4">
        コンタクト<span class="text-red-500">.</span>
      </h2>
      <p class="text-lg text-gray-300 max-w-2xl mx-auto">
        システム開発のご相談から、エンジニア同士の交流まで。<br
          class="hidden sm:block"
        />
        以下のフォームよりお気軽にご連絡ください。
      </p>
    </FadeIn>

    <!-- React Contact Form (Client Side) -->
    <FadeIn
      client:visible
      delay={0.2}
      direction="up"
      className="max-w-3xl mx-auto"
    >
      <ContactForm client:load />
    </FadeIn>

    <!-- Direct Email Fallback -->
    <FadeIn
      client:visible
      delay={0.4}
      direction="up"
      className="mt-16 text-center"
    >
      <p class="text-sm text-gray-500 mb-2">
        フォームが利用できない場合・直接のメールはこちら：
      </p>
      <a
        href="mailto:r.takeuchi@tech-i.net"
        class="inline-flex items-center text-gray-300 hover:text-red-400 transition-colors"
      >
        <svg
          class="w-5 h-5 mr-2"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
          ></path></svg
        >
        r.takeuchi@tech-i.net
      </a>
    </FadeIn>
  </div>
</section>
