---
// Services.astro
---

<section id="services" class="relative py-20 px-4 sm:px-6 lg:px-8 bg-black">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl sm:text-4xl font-black font-plus-jakarta mb-16 text-center">
      サービス<span class="text-red-500">.</span>
    </h2>

    <div class="space-y-6 mb-12">
      <div class="group relative bg-gradient-to-r from-gray-900 to-gray-950 border border-gray-800 rounded-xl p-8 hover:border-red-500/50 hover:shadow-lg hover:shadow-red-500/20 transition-all duration-300 overflow-hidden">
        <div class="absolute top-0 right-0 w-40 h-40 bg-red-600/10 rounded-full -mr-20 -mt-20 group-hover:scale-150 transition-transform duration-300"></div>
        <div class="relative z-10 grid grid-cols-1 md:grid-cols-4 gap-4 items-center">
          <div>
            <h3 class="text-xl font-bold">既存システム機能追加</h3>
            <p class="text-gray-400 text-sm mt-1">CRUD追加、API連携など</p>
          </div>
          <div>
            <p class="text-sm text-gray-500">価格範囲</p>
            <p class="text-lg font-bold text-red-400">3〜30万円</p>
          </div>
          <div>
            <p class="text-sm text-gray-500">納期目安</p>
            <p class="text-lg font-bold text-gray-300">1〜10日</p>
          </div>
          <div class="text-center">
            <p class="text-xs text-red-400 bg-red-400/10 px-3 py-2 rounded inline-block">相場より低価格</p>
          </div>
        </div>
      </div>

      <div class="group relative bg-gradient-to-r from-gray-900 to-gray-950 border border-gray-800 rounded-xl p-8 hover:border-red-500/50 hover:shadow-lg hover:shadow-red-500/20 transition-all duration-300 overflow-hidden">
        <div class="absolute top-0 right-0 w-40 h-40 bg-red-600/10 rounded-full -mr-20 -mt-20 group-hover:scale-150 transition-transform duration-300"></div>
        <div class="relative z-10 grid grid-cols-1 md:grid-cols-4 gap-4 items-center">
          <div>
            <h3 class="text-xl font-bold">HP制作コーディング</h3>
            <p class="text-gray-400 text-sm mt-1">レスポンシブHTML/CSS/JS</p>
          </div>
          <div>
            <p class="text-sm text-gray-500">価格範囲</p>
            <p class="text-lg font-bold text-red-400">2〜20万円</p>
          </div>
          <div>
            <p class="text-sm text-gray-500">納期目安</p>
            <p class="text-lg font-bold text-gray-300">1〜10日</p>
          </div>
          <div class="text-center">
            <p class="text-xs text-red-400 bg-red-400/10 px-3 py-2 rounded inline-block">高速納品</p>
          </div>
        </div>
      </div>

      <div class="group relative bg-gradient-to-r from-gray-900 to-gray-950 border border-gray-800 rounded-xl p-8 hover:border-red-500/50 hover:shadow-lg hover:shadow-red-500/20 transition-all duration-300 overflow-hidden">
        <div class="absolute top-0 right-0 w-40 h-40 bg-red-600/10 rounded-full -mr-20 -mt-20 group-hover:scale-150 transition-transform duration-300"></div>
        <div class="relative z-10 grid grid-cols-1 md:grid-cols-4 gap-4 items-center">
          <div>
            <h3 class="text-xl font-bold">業務自動化スクリプト</h3>
            <p class="text-gray-400 text-sm mt-1">Python、RPA、業務自動化スクリプト開発。定型業務の効率化を実現します。</p>
          </div>
          <div>
            <p class="text-sm text-gray-500">価格範囲</p>
            <p class="text-lg font-bold text-red-400">1〜5万円</p>
          </div>
          <div>
            <p class="text-sm text-gray-500">納期目安</p>
            <p class="text-lg font-bold text-gray-300">1〜3日</p>
          </div>
          <div class="text-center">
            <p class="text-xs text-red-400 bg-red-400/10 px-3 py-2 rounded inline-block">即日対応可能</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>