---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "小型IT開発、HP制作、自動化スクリプト" } = Astro.props;
---

<!doctype html>
<html lang="ja" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<meta name="keywords" content="IT開発, HP制作, 自動化スクリプト, 大阪, フリーランス" />
		<meta name="author" content="合同会社 TECH-i" />
		<meta property="og:title" content="TECH-i | 小型IT開発" />
		<meta property="og:description" content="中小・個人向け、10万円以内の即戦力IT機能追加。大企業開発経験を活かして、高速納品。" />
		<meta property="og:image" content="/assets/images/og-image.svg" />
		<meta property="og:url" content="https://tech-i.github.io" />
		<title>{title}</title>

		<link rel="icon" type="image/svg+xml" href="/assets/images/favicon.svg?v=1" />
		<link rel="shortcut icon" href="/assets/images/favicon.svg?v=1" />
		<link rel="apple-touch-icon" href="/assets/images/apple-touch-icon.png?v=1" />
		<link rel="manifest" href="/manifest.json" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@700;800;900&display=swap" rel="stylesheet" />

		<!-- Schema.org LocalBusiness -->
		<script type="application/ld+json" is:inline>
			{
				"@context": "https://schema.org",
				"@type": "LocalBusiness",
				"name": "合同会社 TECH-i",
				"image": "assets/images/logo.svg",
				"description": "小型IT開発、HP制作、自動化スクリプト",
				"address": {
					"@type": "PostalAddress",
					"addressRegion": "大阪"
				},
				"contactPoint": {
					"@type": "ContactPoint",
					"contactType": "Sales",
					"email": "r.takeuchi@tech-i.net"
				}
			}
		</script>
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-096VWJJK4H" is:inline></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag() {
				dataLayer.push(arguments);
			}
			gtag("js", new Date());

			gtag("config", "G-096VWJJK4H");
		</script>
	</head>
	<body class="bg-black text-white font-sans overflow-x-hidden">
		<slot />
		<script src="https://cdn.jsdelivr.net/npm/tsparticles-slim@2.12.0/tsparticles.slim.bundle.min.js" is:inline></script>
		<script src="/assets/js/particles.js" is:inline></script>
	</body>
</html>